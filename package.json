{
  "name": "myco_nz",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.31.0",
  "scripts": {
    "dev": "vinext dev --port 3001",
    "build": "vinext build",
    "start": "wrangler dev --config dist/server/wrangler.json",
    "dev:next": "next dev",
    "build:next": "next build",
    "start:next": "next start",
    "typecheck": "vinext typegen && tsc --noEmit",
    "lint": "eslint .",
    "quality": "pnpm typecheck && pnpm lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "update:place-names": "node scripts/update-nz-place-names.mjs",
    "check:bindings": "wrangler types --check",
    "check:vinext": "vinext check",
    "verify": "pnpm check:bindings && pnpm quality && pnpm test && pnpm check:vinext && pnpm build",
    "dev:vinext": "vinext dev --port 3001",
    "build:vinext": "vinext build",
    "start:vinext": "wrangler dev --config dist/server/wrangler.json",
    "deploy:vinext": "vinext-cloudflare deploy --config dist/server/wrangler.json"
  },
  "dependencies": {
    "@vinext/cloudflare": "1.0.0-beta.1",
    "h3-js": "4.5.0",
    "lucide-react": "1.24.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-server-dom-webpack": "19.2.7",
    "vinext": "1.0.0-beta.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@cloudflare/vite-plugin": "1.44.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "latest",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "6.0.3",
    "@vitejs/plugin-rsc": "0.5.27",
    "csv-parse": "^7.0.1",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "jsdom": "^29.1.1",
    "tailwindcss": "latest",
    "typescript": "^5.9.3",
    "vite": "8.1.4",
    "vitest": "^4.1.10",
    "wrangler": "4.110.0"
  },
  "type": "module"
}
