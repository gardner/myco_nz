{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "myco-nz",
  "compatibility_date": "2026-07-12",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": "vinext/server/fetch-handler",
  "assets": {
    "directory": "dist/client",
    "not_found_handling": "none",
    "binding": "ASSETS"
  },
  "cache": {
    "enabled": true,
    "cross_version_cache": false
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
